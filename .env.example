# Company Decision Monitor v0.1.1
# Do not commit a real .env file. User API keys are configured inside the app
# and stored in the user's AppData directory.

CDM_APP_VERSION=0.1.3
CDM_APP_MODE="Open-Source Data Mode"
CDM_APP_USER_AGENT="CompanyDecisionMonitor/0.1.3"
CDM_REQUEST_TIMEOUT_SECONDS=15
CDM_CACHE_TTL_SECONDS=900
CDM_NETWORK_RETRY_COUNT=2
